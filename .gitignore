# ------------------------------------------------------------
# Root-level ignores (safe for any project)
# ------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# Keep env examples, ignore real env files
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Client folder ignores
# ------------------------------------------------------------
client/node_modules/
client/.pnpm-store/
client/.npm/
client/.yarn/

client/dist/
client/build/
client/.next/
client/out/
client/coverage/
client/.turbo/
client/.cache/
client/.vercel/
client/*.tsbuildinfo

client/.env
client/.env.*
!client/.env.example

# ------------------------------------------------------------
# Server folder ignores
# ------------------------------------------------------------
server/node_modules/
server/.pnpm-store/
server/.npm/
server/.yarn/

server/dist/
server/build/
server/out/
server/coverage/
server/.cache/
server/*.tsbuildinfo

server/.env
server/.env.*
!server/.env.example

# Prisma local/dev artifacts
server/prisma/*.db
server/prisma/*.db-journal